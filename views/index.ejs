<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>post</title>
     <link rel="stylesheet" href="/app.css" />
</head>
<body>
    <h2 class="cont">Quara post</h2>
   <% for(post of posts) { %>
        <div class="post">
            <h1 class="user">@<%=post.username%></h1>
            <h1 class="content"><%=post.content%></h1>
            <a href="http://localhost:8080/posts/<%=post.id%>">see details</a>
            <a href="http://localhost:8080/posts/<%=post.id%>/edit">edit</a>
            <form method="post" action="/posts/<%=post.id%>?_method=DELETE">
            <button>delete</button>
            </form>
        </div>
   <% } %>
   <br/>
   <a class="create" href="http://localhost:8080/posts/new">create new post</a>

</body>
</html>